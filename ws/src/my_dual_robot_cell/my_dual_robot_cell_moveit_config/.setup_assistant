moveit_setup_assistant_config:
  urdf:
    package: my_dual_robot_cell_control
    relative_path: urdf/my_dual_robot_cell_controlled.urdf.xacro
    xacro_args: "alice_ur_type:=ur3e bob_ur_type:=ur5e alice_use_mock_hardware:=true bob_use_mock_hardware:=true"
  srdf:
    relative_path: config/my_dual_robot_cell.srdf
  package_settings:
    author_name: Felix Exner
    author_email: exner@fzi.de
  control_xacro:
    command:
      - position
    state:
      - position
      - velocity
  modified_urdf:
    xacros:
      - control_xacro
